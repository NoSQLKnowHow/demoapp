# ============================================================================
# PRISM: Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values.
# ============================================================================

# Database Connection
ORACLE_DSN=your_adb_tns_name
ORACLE_USER=prism
ORACLE_PASSWORD=your_password
ORACLE_WALLET_DIR=/path/to/wallet

# OCI Generative AI (for seed data generation)
OCI_COMPARTMENT_ID=ocid1.compartment.oc1..your_compartment_id
OCI_GENAI_ENDPOINT=https://inference.generativeai.us-chicago-1.oci.oraclecloud.com
OCI_GENAI_MODEL=meta.llama-3.2-90b-vision-instruct

# MongoDB API (Oracle Database API for MongoDB)
MONGODB_URI=mongodb://prism:your_password@your_host:27017/prism?authMechanism=PLAIN&tls=true

# Authentication (for Prism web app)
PRISM_AUTH_USERNAME=demo
PRISM_AUTH_PASSWORD=your_demo_password

# Application Mode
PRISM_MODE=local
PRISM_ALLOW_WRITES=true
