# ============================================================================
# PRISM: Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values.
# ============================================================================

# Database Connection
ORACLE_DSN=192.168.69.20:1521/FREEPDB1
ORACLE_USER=prism
ORACLE_PASSWORD=CHANGE_ME
ORACLE_WALLET_DIR=

# ============================================================================
# LLM Provider for seed data generation
# Options: oci, claude, openai
# ============================================================================
LLM_PROVIDER=openai

# --- OCI Generative AI ---
# Required when LLM_PROVIDER=oci
OCI_COMPARTMENT_ID=ocid1.compartment.oc1..your_compartment_id
OCI_GENAI_ENDPOINT=https://inference.generativeai.us-chicago-1.oci.oraclecloud.com
OCI_GENAI_MODEL=meta.llama-3.2-90b-vision-instruct

# --- Anthropic Claude ---
# Required when LLM_PROVIDER=claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- OpenAI ---
# Required when LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# MongoDB API (Oracle Database API for MongoDB)
MONGODB_URI=mongodb://prism:your_password@your_host:27017/prism?authMechanism=PLAIN&tls=true

# Authentication (for Prism web app)
PRISM_AUTH_USERNAME=demo
PRISM_AUTH_PASSWORD=your_demo_password

# Application Mode
PRISM_MODE=local
PRISM_ALLOW_WRITES=true
